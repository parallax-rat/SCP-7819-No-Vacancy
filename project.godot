; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="No Vacancy"
config/version="1.0"
config/tags=PackedStringArray("3d", "first_person", "horror", "psx", "single_player")
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/stretch_mode=4
boot_splash/image="uid://byogpkgyb0j2t"
config/icon="uid://byogpkgyb0j2t"

[autoload]

PlayerStats="*res://Scripts/PlayerStats.gd"
psx_autoload="*uid://u3y0jxl0vtmg"
PhantomCameraManager="*uid://duq6jhf6unyis"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/M.A.V.S/plugin.cfg", "res://addons/phantom_camera/plugin.cfg", "res://addons/proton_scatter/plugin.cfg", "res://addons/psx/plugin.cfg", "res://addons/road-generator/plugin.cfg", "res://addons/script-ide/plugin.cfg", "res://addons/shader_library/plugin.cfg", "res://addons/terrain_splitter/plugin.cfg")

[global_group]

Object=""
Interactable=""
Breakable=""
Wall=""

